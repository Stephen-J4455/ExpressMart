{
  "expo": {
    "name": "ExpressMart",
    "slug": "ExpressMart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/express.png",
    "userInterfaceStyle": "light",
    "scheme": "expressmart",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/express.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "expirements":{
      "baseUrl": "https://stephen-j4455.github.io/expressmartweb/"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stephenj3.ExpressMart",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.stephenj3.ExpressMart",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "com.google.android.c2dm.permission.RECEIVE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "expressmart"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/express.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/express.png",
          "color": "#ffffff",
          "androidMode": "default",
          "androidCollapsedTitle": "ExpressMart"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "bf1e4bb1-228e-4e48-a56b-748b7f32980c"
      },
      "firebaseApiKey": "AIzaSyBqrV1yGWsLj17JXFwfIWRP-sqX6hp8vLk",
      "firebaseAuthDomain": "expressmart-7d550.firebaseapp.com",
      "firebaseProjectId": "expressmart-7d550",
      "firebaseStorageBucket": "expressmart-7d550.firebasestorage.app",
      "firebaseMessagingSenderId": "499123636329",
      "firebaseAppId": "1:499123636329:web:9a96c3d4b6ed11c3f57af8",
      "firebaseVapidKey": "YOUR_VAPID_KEY",
      "measurementId": "G-Q63D7TJQRK"
    }
  }
}
